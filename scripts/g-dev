#!/usr/bin/env python3

import argparse
import json
import os
import signal
import subprocess
import sys
import time
from pathlib import Path
from typing import Any, TypedDict


ROOT = Path(__file__).resolve().parents[1]
INSTANCE_DIRECTORY = ROOT / "instance"
LOG_DIRECTORY = INSTANCE_DIRECTORY / "logs"
RUN_DIRECTORY = INSTANCE_DIRECTORY / "run"
STATE_FILE = RUN_DIRECTORY / "g-dev.json"


class ServerConfiguration(TypedDict):
    init: list[str]
    start: list[str]
    log: Path
    url: str


class ServiceState(TypedDict):
    pid: int
    command: list[str]
    log: str
    started_at: str


SERVER_CONFIGURATIONS: dict[str, ServerConfiguration] = {
    "web": {
        "init": [sys.executable, "-m", "flask", "--app", "app.main", "init-db"],
        "start": [
            sys.executable,
            "-m",
            "flask",
            "--app",
            "app.main",
            "run",
            "--debug",
            "--no-reload",
            "--host",
            "0.0.0.0",
        ],
        "log": LOG_DIRECTORY / "web.log",
        "url": "http://127.0.0.1:5000",
    }
}


def ensure_directories() -> None:
    LOG_DIRECTORY.mkdir(parents=True, exist_ok=True)
    RUN_DIRECTORY.mkdir(parents=True, exist_ok=True)


def load_state() -> dict[str, ServiceState]:
    if not STATE_FILE.exists():
        return {}
    try:
        state = json.loads(STATE_FILE.read_text(encoding="utf-8"))
        return state if isinstance(state, dict) else {}
    except json.JSONDecodeError:
        return {}


def save_state(state: dict[str, ServiceState]) -> None:
    ensure_directories()
    STATE_FILE.write_text(json.dumps(state, indent=2, sort_keys=True), encoding="utf-8")


def remove_service_state(name: str) -> None:
    state = load_state()
    if name in state:
        del state[name]
        save_state(state)


def process_exists(process_id: int) -> bool:
    if process_id <= 0:
        return False

    if os.name == "nt":
        result = subprocess.run(
            ["tasklist", "/FI", f"PID eq {process_id}", "/FO", "CSV", "/NH"],
            capture_output=True,
            text=True,
            check=False,
        )
        return str(process_id) in result.stdout

    try:
        os.kill(process_id, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


def creation_options() -> dict[str, Any]:
    if os.name == "nt":
        return {"creationflags": subprocess.CREATE_NEW_PROCESS_GROUP}
    return {"start_new_session": True}


def run_initialization(name: str, configuration: ServerConfiguration) -> None:
    ensure_directories()
    print(f"Initializing {name}...", flush=True)
    result = subprocess.run(configuration["init"], cwd=ROOT, check=False)
    if result.returncode != 0:
        raise SystemExit(f"Initialization failed for {name} with exit code {result.returncode}.")


def start_server(name: str, configuration: ServerConfiguration) -> None:
    ensure_directories()
    state = load_state()
    current = state.get(name, {})
    process_id = int(current.get("pid", 0) or 0)

    if process_exists(process_id):
        print(f"{name} is already running with PID {process_id}.")
        return

    run_initialization(name, configuration)

    log_path = configuration["log"]
    log_file = log_path.open("ab", buffering=0)
    log_file.write(f"\n--- g-dev start {time.strftime('%Y-%m-%d %H:%M:%S')} ---\n".encode("utf-8"))

    process = subprocess.Popen(
        configuration["start"],
        cwd=ROOT,
        stdout=log_file,
        stderr=subprocess.STDOUT,
        stdin=subprocess.DEVNULL,
        close_fds=os.name != "nt",
        **creation_options(),
    )
    log_file.close()

    state[name] = {
        "pid": process.pid,
        "command": configuration["start"],
        "log": str(log_path.relative_to(ROOT)),
        "started_at": time.strftime("%Y-%m-%d %H:%M:%S"),
    }
    save_state(state)
    print(f"Started {name} with PID {process.pid}.")
    if configuration.get("url"):
        print(f"{name} URL: {configuration['url']}")
    print(f"Logs: {log_path.relative_to(ROOT)}")


def stop_process_tree(process_id: int) -> bool:
    if os.name == "nt":
        return subprocess.run(["taskkill", "/PID", str(process_id), "/T", "/F"], check=False).returncode == 0

    try:
        os.killpg(process_id, signal.SIGTERM)
    except ProcessLookupError:
        return True

    deadline = time.time() + 5
    while time.time() < deadline:
        if not process_exists(process_id):
            return True
        time.sleep(0.2)

    try:
        os.killpg(process_id, signal.SIGKILL)
    except ProcessLookupError:
        return True
    return True


def stop_server(name: str) -> None:
    state = load_state()
    current = state.get(name, {})
    process_id = int(current.get("pid", 0) or 0)

    if not process_exists(process_id):
        print(f"{name} is not running.")
        remove_service_state(name)
        return

    if stop_process_tree(process_id):
        print(f"Stopped {name} with PID {process_id}.")
        remove_service_state(name)
    else:
        raise SystemExit(f"Failed to stop {name} with PID {process_id}.")


def read_last_lines(path: Path, line_count: int) -> list[str]:
    if line_count <= 0 or not path.exists():
        return []
    with path.open("rb") as file:
        file.seek(0, os.SEEK_END)
        position = file.tell()
        buffer = bytearray()
        lines_seen = 0

        while position > 0 and lines_seen <= line_count:
            read_size = min(4096, position)
            position -= read_size
            file.seek(position)
            chunk = file.read(read_size)
            buffer[:0] = chunk
            lines_seen += chunk.count(b"\n")

    return buffer.decode("utf-8", errors="replace").splitlines()[-line_count:]


def tail_file(path: Path, line_count: int, follow: bool) -> None:
    if not path.exists():
        print(f"No log file yet: {path.relative_to(ROOT)}")
        return

    for line in read_last_lines(path, line_count):
        print(line)

    if not follow:
        return

    with path.open("r", encoding="utf-8", errors="replace") as file:
        file.seek(0, os.SEEK_END)
        try:
            while True:
                line = file.readline()
                if line:
                    print(line, end="")
                else:
                    time.sleep(0.5)
        except KeyboardInterrupt:
            print()


def start_command(arguments: argparse.Namespace) -> None:
    del arguments
    for name, configuration in SERVER_CONFIGURATIONS.items():
        start_server(name, configuration)


def stop_command(arguments: argparse.Namespace) -> None:
    del arguments
    for name in SERVER_CONFIGURATIONS:
        stop_server(name)


def restart_command(arguments: argparse.Namespace) -> None:
    del arguments
    for name, configuration in SERVER_CONFIGURATIONS.items():
        stop_server(name)
        start_server(name, configuration)


def logs_command(arguments: argparse.Namespace) -> None:
    for index, (name, configuration) in enumerate(SERVER_CONFIGURATIONS.items()):
        if len(SERVER_CONFIGURATIONS) > 1:
            if index:
                print()
            print(f"==> {name} <==")
        tail_file(configuration["log"], arguments.lines, arguments.follow)


def status_command(arguments: argparse.Namespace) -> None:
    del arguments
    state = load_state()
    for name, configuration in SERVER_CONFIGURATIONS.items():
        process_id = int(state.get(name, {}).get("pid", 0) or 0)
        if process_exists(process_id):
            service_url = f", url {configuration['url']}" if configuration.get("url") else ""
            print(f"{name}: running, PID {process_id}, log {configuration['log'].relative_to(ROOT)}{service_url}")
        else:
            print(f"{name}: stopped")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="g-dev",
        description="Manage game1 development server processes.",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    start = subparsers.add_parser("start", help="initialize if needed and start server(s) in the background")
    start.set_defaults(func=start_command)

    stop = subparsers.add_parser("stop", help="stop background server(s)")
    stop.set_defaults(func=stop_command)

    restart = subparsers.add_parser("restart", help="stop then start server(s)")
    restart.set_defaults(func=restart_command)

    logs = subparsers.add_parser("logs", help="tail server log output")
    logs.add_argument("-n", "--lines", type=int, default=80, help="number of previous lines to show (default: 80)")
    logs.add_argument("-f", "--follow", action="store_true", default=True, help="keep following logs (default)")
    logs.add_argument("--no-follow", action="store_false", dest="follow", help="print recent logs and exit")
    logs.set_defaults(func=logs_command)

    status = subparsers.add_parser("status", help="show server status")
    status.set_defaults(func=status_command)

    return parser


def main(arguments: list[str] | None = None) -> None:
    parser = build_parser()
    parsed_arguments = parser.parse_args(arguments)
    parsed_arguments.func(parsed_arguments)


if __name__ == "__main__":
    main()
